# Admin password (set a strong secret)
ADMIN_TOKEN=change-me-to-something-secret

# Twilio credentials (from twilio.com console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567

# Optional: Twilio Conversations service SID for group chats
# Create at: twilio.com/console/conversations/services
TWILIO_CONVERSATIONS_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your app's public URL (for delegation links)
BASE_URL=https://yourdomain.com

# Google Maps API key (needs Maps JavaScript API + Places API enabled)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Port (default 3001)
PORT=3001

# Timezone for scheduling (2-day reminders, 4pm group chat)
TZ=America/Los_Angeles
